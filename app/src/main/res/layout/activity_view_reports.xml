<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/white">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Canal Reports"
            android:textSize="26sp"
            android:textStyle="bold"
            android:textColor="@color/primary_green"
            android:layout_marginBottom="20dp"/>

        <!-- PASTE ALERT BANNER HERE -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="14dp"
            android:background="@color/status_red"
            android:layout_marginBottom="20dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🚨"
                android:textSize="22sp"
                android:layout_marginEnd="10dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Critical Breach Detected in Section B"
                android:textColor="@android:color/white"
                android:textStyle="bold"
                android:textSize="16sp"/>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp"
            android:background="@drawable/border_rounded"
            android:layout_marginBottom="20dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Water Level Status"
                android:textStyle="bold"
                android:textSize="18sp"
                android:textColor="@color/primary_green"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Primary Canal: 78% Full"
                android:textColor="@color/text_primary"
                android:layout_marginTop="8dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Secondary Canal: Moderate Flow"
                android:textColor="@color/text_primary"
                android:layout_marginTop="6dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Last Updated: 10:45 AM"
                android:textColor="@color/text_secondary"
                android:layout_marginTop="6dp"/>

        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp"
            android:background="@drawable/border_rounded"
            android:layout_marginBottom="20dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Engineer Monitoring Summary"
                android:textStyle="bold"
                android:textSize="18sp"
                android:textColor="@color/primary_green"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Total Reports Today: 12"
                android:textColor="@color/text_primary"
                android:layout_marginTop="8dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Active Canal Issues: 4"
                android:textColor="@color/status_red"
                android:layout_marginTop="6dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Canal Health Status: Stable"
                android:textColor="@color/status_green"
                android:layout_marginTop="6dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Monitored Villages: Harohalli, Ramanagara, Kanakapura"
                android:textColor="@color/text_secondary"
                android:layout_marginTop="6dp"/>

        </LinearLayout>

        <!-- Latest Submitted Report -->

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp"
            android:background="@drawable/border_rounded"
            android:layout_marginBottom="20dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Latest Submitted Report"
                android:textStyle="bold"
                android:textSize="18sp"
                android:textColor="@color/primary_green"
                android:layout_marginBottom="10dp"/>

            <TextView
                android:id="@+id/tvDynamicTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="No Reports Yet"
                android:textStyle="bold"
                android:textSize="16sp"
                android:textColor="@color/text_primary"/>

            <TextView
                android:id="@+id/tvDynamicDescription"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text=""
                android:textColor="@color/text_secondary"
                android:layout_marginTop="6dp"/>

            <TextView
                android:id="@+id/tvDynamicLocation"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text=""
                android:textColor="@color/text_secondary"
                android:layout_marginTop="6dp"/>
        </LinearLayout>

        <!-- Report Card 1 -->

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp"
            android:background="@drawable/border_rounded"
            android:layout_marginBottom="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Canal Breach - Section A"
                android:textStyle="bold"
                android:textSize="18sp"
                android:textColor="@color/primary_green"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Leak detected near Tail-End farm."
                android:textColor="@color/text_primary"
                android:layout_marginTop="6dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Updated: 10:45 AM"
                android:textColor="@color/text_secondary"
                android:layout_marginTop="6dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Status: Pending"
                android:textColor="@color/status_red"
                android:layout_marginTop="4dp"/>
        </LinearLayout>

        <!-- Report Card 2 -->

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp"
            android:background="@drawable/border_rounded"
            android:layout_marginBottom="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Silt Alert - Section B"
                android:textStyle="bold"
                android:textSize="18sp"
                android:textColor="@color/primary_green"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Heavy silt reducing water flow."
                android:textColor="@color/text_primary"
                android:layout_marginTop="6dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Updated: 09:20 AM"
                android:textColor="@color/text_secondary"
                android:layout_marginTop="6dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Status: In Review"
                android:textColor="@color/status_orange"
                android:layout_marginTop="4dp"/>
        </LinearLayout>

        <!-- Report Card 3 -->

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp"
            android:background="@drawable/border_rounded">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Water Reached Village X"
                android:textStyle="bold"
                android:textSize="18sp"
                android:textColor="@color/primary_green"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Water flow normal today."
                android:textColor="@color/text_primary"
                android:layout_marginTop="6dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Updated: 08:10 AM"
                android:textColor="@color/text_secondary"
                android:layout_marginTop="6dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Status: Active"
                android:textColor="@color/status_green"
                android:layout_marginTop="4dp"/>
        </LinearLayout>

    </LinearLayout>

</ScrollView>